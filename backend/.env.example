# ── Runtime ────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB Atlas (or local mongodb://localhost:27017/sai_physiotherapy) ──
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/sai_physiotherapy?retryWrites=true&w=majority

# ── JWT (use 32+ char random strings in production) ────────
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_REFRESH_SECRET=your_refresh_secret_key_minimum_32_characters_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Frontend URL (CORS allow-list) ─────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Cloudinary (patient documents, blog images, gallery) ──
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (SMTP — appointment confirmations, receipts) ────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=clinic@saiphysiotherapy.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=SAI Physiotherapy <clinic@saiphysiotherapy.com>

# ── SMS Provider ──────────────────────────────────────────
# Options: msg91 | twilio | none
SMS_PROVIDER=none
MSG91_API_KEY=your_msg91_api_key
MSG91_SENDER_ID=SAIPHYS
MSG91_TEMPLATE_CONFIRMED=your_template_id
MSG91_TEMPLATE_RECEIPT=your_template_id

# ── WhatsApp (WATI / 360dialog) ───────────────────────────
WHATSAPP_API_URL=https://live-mt-server.wati.io/api/v1
WHATSAPP_API_TOKEN=your_wati_token

# ── Redis (optional — session caching, rate-limit store) ──
REDIS_URL=redis://localhost:6379
